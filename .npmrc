registry=https://registry.npmjs.org/

# DWP private package registry
registry=https://registry.npmjs.org/
@dwp:registry=https://gitlab.com/api/v4/packages/npm/
//gitlab.com/api/v4/packages/npm/:_authToken=${GITLAB_REGISTRY_ACCESS_TOKEN}

# Authentication token (keep this line!)
# Replace YOUR_TOKEN below with your real token
//gitlab.com/api/v4/projects/carers-allowance-prototype/packages/npm/:_authToken=PASTE-ACCESS-TOKEN

strict-ssl=false
cafile=/etc/ssl/cert.pem
always-auth=true